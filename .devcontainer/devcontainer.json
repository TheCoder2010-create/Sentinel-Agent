{
  "name": "Sentinel AI — Development",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "ms-python.python",
        "ms-python.black-formatter",
        "bazelbuild.vscode-bazel",
        "GitHub.vscode-github-actions",
        "vadimcn.vscode-lldb",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "rust-analyzer.cargo.features": "all",
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.cargo.allTargets": true,
        "editor.formatOnSave": true,
        "editor.renderWhitespace": "boundary",
        "files.eol": "\n",
        "files.insertFinalNewline": true
      }
    }
  },
  "postCreateCommand": "python3 .devcontainer/post_install.py",
  "postStartCommand": "python3 .devcontainer/post_install.py",
  "mounts": [
    "source=sentinel-bashhistory,target=/commandhistory,type=volume",
    "source=sentinel-cargocache,target=/usr/local/cargo/registry,type=volume"
  ],
  "remoteUser": "vscode",
  "containerEnv": {
    "SENTINEL_DEVCONTAINER": "1",
    "CARGO_NET_GIT_FETCH_WITH_CLI": "true",
    "CARGO_REGISTRIES_CRATES_IO_PROTOCOL": "sparse"
  }
}
