{
  "name": "Sentinel AI — Secure (Network-Restricted)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "ms-python.python",
        "bazelbuild.vscode-bazel",
        "vadimcn.vscode-lldb"
      ],
      "settings": {
        "rust-analyzer.cargo.features": "all",
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.cargo.allTargets": true,
        "editor.formatOnSave": true,
        "files.eol": "\n",
        "files.insertFinalNewline": true
      }
    }
  },
  "postCreateCommand": "python3 .devcontainer/post_install.py",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "mounts": [
    "source=sentinel-bashhistory-secure,target=/commandhistory,type=volume",
    "source=sentinel-cargocache-secure,target=/usr/local/cargo/registry,type=volume"
  ],
  "remoteUser": "vscode",
  "containerEnv": {
    "SENTINEL_DEVCONTAINER": "1",
    "SENTINEL_SECURE": "1",
    "SENTINEL_SANDBOX_BWRAP": "/usr/bin/bwrap",
    "CARGO_NET_GIT_FETCH_WITH_CLI": "true",
    "CARGO_REGISTRIES_CRATES_IO_PROTOCOL": "sparse",
    "OPENAI_ALLOWED_DOMAINS": "github.com api.github.com crates.io static.crates.io index.crates.io pypi.org files.pythonhosted.org npmjs.org registry.npmjs.org nodejs.org objects.githubusercontent.com api.sentinel-ai.dev"
  },
  "securityOpt": ["seccomp=unconfined"],
  "capAdd": ["NET_ADMIN", "NET_RAW", "SYS_ADMIN"]
}
