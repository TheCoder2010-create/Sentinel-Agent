# ---------------------------------------------------------------------------
# Sentinel AI — Platform definitions
#
# Defines constraint_values and platform targets for all supported
# build and release configurations.
# ---------------------------------------------------------------------------

package(default_visibility = ["//visibility:public"])

# ---------------------------------------------------------------------------
# OS constraints
# ---------------------------------------------------------------------------
constraint_value(
    name = "linux",
    constraint_setting = "@platforms//os:os",
)

constraint_value(
    name = "windows",
    constraint_setting = "@platforms//os:os",
)

constraint_value(
    name = "macos",
    constraint_setting = "@platforms//os:os",
)

# ---------------------------------------------------------------------------
# CPU constraints
# ---------------------------------------------------------------------------
constraint_value(
    name = "x86_64",
    constraint_setting = "@platforms//cpu:cpu",
)

constraint_value(
    name = "aarch64",
    constraint_setting = "@platforms//cpu:cpu",
)

# ---------------------------------------------------------------------------
# Compiler constraints
# ---------------------------------------------------------------------------
constraint_value(
    name = "msvc",
    constraint_setting = "@bazel_tools//tools/cpp:compiler",
)

constraint_value(
    name = "clang",
    constraint_setting = "@bazel_tools//tools/cpp:compiler",
)

constraint_value(
    name = "gcc",
    constraint_setting = "@bazel_tools//tools/cpp:compiler",
)

# ---------------------------------------------------------------------------
# Release platforms
# ---------------------------------------------------------------------------

# Linux x86_64 (glibc 2.28) — manylinux2014 baseline
platform(
    name = "linux_x86_64_release",
    constraint_values = [
        ":linux",
        ":x86_64",
        ":gcc",
        "@rules_rust//rust:channel_stable",
    ],
)

# Linux ARM64 (glibc 2.28)
platform(
    name = "linux_aarch64_release",
    constraint_values = [
        ":linux",
        ":aarch64",
        ":gcc",
        "@rules_rust//rust:channel_stable",
    ],
)

# Windows x86_64 MSVC
platform(
    name = "windows_x86_64_release",
    constraint_values = [
        ":windows",
        ":x86_64",
        ":msvc",
        "@rules_rust//rust:channel_stable",
    ],
)

# Windows ARM64 MSVC
platform(
    name = "windows_aarch64_release",
    constraint_values = [
        ":windows",
        ":aarch64",
        ":msvc",
        "@rules_rust//rust:channel_stable",
    ],
)

# macOS x86_64 (Intel)
platform(
    name = "macos_x86_64_release",
    constraint_values = [
        ":macos",
        ":x86_64",
        ":clang",
        "@rules_rust//rust:channel_stable",
    ],
)

# macOS ARM64 (Apple Silicon)
platform(
    name = "macos_aarch64_release",
    constraint_values = [
        ":macos",
        ":aarch64",
        ":clang",
        "@rules_rust//rust:channel_stable",
    ],
)

# ---------------------------------------------------------------------------
# Cross-compilation test platforms
# ---------------------------------------------------------------------------

# Windows GNU-LLVM (MinGW-style via LLVM) — used for cross-compilation
# testing where the host is MSVC but we validate gnullvm codegen.
platform(
    name = "windows_x86_64_gnullvm",
    constraint_values = [
        ":windows",
        ":x86_64",
        ":clang",
        "@rules_rust//rust:channel_stable",
    ],
)

# ---------------------------------------------------------------------------
# Platform aliases for common queries
# ---------------------------------------------------------------------------

alias(
    name = "host",
    actual = select({
        "@bazel_tools//src/conditions:linux_x86_64": ":linux_x86_64_release",
        "@bazel_tools//src/conditions:linux_aarch64": ":linux_aarch64_release",
        "@bazel_tools//src/conditions:windows": ":windows_x86_64_release",
        "@bazel_tools//src/conditions:darwin_x86_64": ":macos_x86_64_release",
        "@bazel_tools//src/conditions:darwin_arm64": ":macos_aarch64_release",
        "//conditions:default": ":linux_x86_64_release",
    }),
)
